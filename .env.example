# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: gemini | openai | groq
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash

# ── API Keys (only the one you use is required) ───────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── Vector Store ───────────────────────────────────────────────────────────────
# Choose one: faiss | chroma
VECTOR_STORE=faiss

# ── Storage Paths ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
VECTORSTORE_DIR=vectorstores

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=Multi-Agent Research Assistant
APP_VERSION=1.0.0
DEBUG=false
