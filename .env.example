# ── API Keys ────────────────────────────────────────────────────────────────
# GEMINI_API_KEY is required — it powers document embeddings (RAG) regardless
# of which provider you use for chat. The others are optional fallbacks for
# chat/research generation only — if the primary LLM call errors out (rate
# limit, outage, bad key), it's automatically retried on the next configured
# provider.
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# ── Model overrides (optional) ─────────────────────────────────────────────
# Providers periodically deprecate model IDs. If a default below stops
# working, check the provider's docs and override it here instead of
# editing code.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile
DEEPSEEK_MODEL=deepseek-chat

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API from a browser.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── App Metadata ────────────────────────────────────────────────────────────
APP_NAME="Multi-Agent Research Assistant"
APP_VERSION="1.0.0"
DEBUG=True
